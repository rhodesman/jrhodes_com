{
  "name": "jrhodes_com",
  "version": "2.0.0",
  "description": "Jason Rhodes's website",
  "main": "app.js",
  "scripts": {
    "build": "vite build --config client/vite.config.ts",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "nodemon app.js",
    "dev": "concurrently -n client,server -c cyan,magenta \"npm:dev:client\" \"npm:dev:server\"",
    "typecheck": "tsc --noEmit -p client/tsconfig.json",
    "start": "npm run build && node app.js",
    "serve": "node app.js",
    "test": "node --inspect app.js"
  },
  "author": "Jason Rhodes",
  "license": "ISC",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "bootstrap": "^5.3.8",
    "express": "^5.2.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.14",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
